# Secrets de las Edge Functions.
# Local:  copiar a supabase/functions/.env y correr:
#   supabase functions serve --env-file supabase/functions/.env
# Deploy: setear con `supabase secrets set --env-file supabase/functions/.env`
#
# NOTA: SUPABASE_URL y SUPABASE_SERVICE_ROLE_KEY los inyecta el runtime solo
# (tanto en local como en deploy) — NO hace falta ponerlos acá.

# Secret compartido para ManyChat / Calendly(Zapier) / Fathom(Zapier).
# Cada webhook debe mandar el header:  x-webhook-secret: <este valor>
WEBHOOK_SECRET=cambiar-por-un-secreto-largo-y-aleatorio

# hottok de Hotmart (Configuración > Webhook en Hotmart). Se manda como header
# x-hotmart-hottok. Si se deja vacío, el webhook de Hotmart cae al WEBHOOK_SECRET.
HOTMART_HOTTOK=

# signing_key del webhook NATIVO de Calendly. Lo genera y carga automáticamente
# scripts/register-calendly-webhook.sh (no hace falta ponerlo a mano). La función
# calendly-webhook valida con esto el header Calendly-Webhook-Signature.
CALENDLY_SIGNING_KEY=

# (Opcional) texto EXACTO de la pregunta del formulario de Calendly que contiene
# el Instagram. Si no se setea, la función lo detecta por heurística.
CALENDLY_IG_QUESTION=
